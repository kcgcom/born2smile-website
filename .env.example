# 카카오맵 JavaScript 앱 키
# https://developers.kakao.com 에서 발급
# 1. 카카오 개발자 사이트 접속 → 내 애플리케이션 → 앱 추가
# 2. 앱 키 → JavaScript 키 복사
# 3. 플랫폼 → Web 사이트 도메인 등록 (예: http://localhost:3000)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_map_app_key_here

# Supabase (DB + Auth)
# https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 관리자 대시보드 접근 허용 이메일 (쉼표 구분)
ADMIN_EMAILS=kcgcom@gmail.com

# 관리자 대시보드 — 트래픽 탭 (GA4 Data API)
# Google Analytics → 관리 → 속성 설정 → 속성 ID (숫자만)
GA4_PROPERTY_ID=525397980

# 관리자 대시보드 — 검색/SEO 탭 (Search Console API)
# 권한을 부여한 속성과 정확히 맞춰야 함
# 예: sc-domain:born2smile.co.kr 또는 https://www.born2smile.co.kr/
SEARCH_CONSOLE_SITE_URL=sc-domain:born2smile.co.kr

# 관리자 대시보드 — 검색/SEO 탭 네이버 트렌드 (DataLab API)
# https://developers.naver.com/apps → 애플리케이션 등록 → 데이터랩(검색어트렌드) 선택
NAVER_DATALAB_CLIENT_ID=your_naver_client_id_here
NAVER_DATALAB_CLIENT_SECRET=your_naver_client_secret_here

# 개발 대시보드 — 성능 탭 (PageSpeed Insights API)
# https://console.cloud.google.com/apis/credentials → API 키 생성
# PageSpeed Insights API 활성화 필요: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Google 서비스 계정 JSON 키 (GA4/Search Console API, 로컬 개발용)
# 프로덕션은 Cloud Run ADC 사용
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...",...}

# Sentry (에러 모니터링)
# 1. Sentry 프로젝트 생성 → Settings > Projects > Client Keys (DSN)
# 2. Organization slug / Project slug / Auth Token 발급
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_ENVIRONMENT=production
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog (행동 분석 + 관리자 전환 리포트)
# 1. Managed reverse proxy 사용 시 NEXT_PUBLIC_POSTHOG_HOST를 우리 도메인 서브도메인으로 설정
#    예: https://x.born2smile.co.kr
# 2. NEXT_PUBLIC_POSTHOG_UI_HOST / POSTHOG_BASE_URL는 PostHog 앱 주소(미국 리전은 https://us.posthog.com)
# 3. Project Settings에서 Project ID 확인
# 4. Personal API Keys에서 Query Read scope 키 발급
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://x.born2smile.co.kr
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=
POSTHOG_BASE_URL=https://us.posthog.com

# 관리자 대시보드 — AI 블로그 작성 도우미
# 서버 전용 LLM 프록시 대상 (브라우저에 직접 노출하지 않음)
LLM_BASE_URL=https://llm.born2smile.co.kr
LLM_MODEL=fast
