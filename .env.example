# 카카오맵 JavaScript 앱 키
# https://developers.kakao.com 에서 발급
# 1. 카카오 개발자 사이트 접속 → 내 애플리케이션 → 앱 추가
# 2. 앱 키 → JavaScript 키 복사
# 3. 플랫폼 → Web 사이트 도메인 등록 (예: http://localhost:3000)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_map_app_key_here

# Firebase 클라이언트 설정 (Firestore 좋아요 기능)
# https://console.firebase.google.com → 프로젝트 설정 → 웹 앱 구성
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seoul-born2smile

# Notion CMS 연동 (블로그)
# 설정하지 않으면 기존 .ts 파일 기반으로 동작합니다.
# 1. https://www.notion.so/my-integrations 에서 Integration 생성
# 2. Notion API Key 입력
# 3. 마이그레이션 스크립트 실행 후 생성된 Database ID 입력
NOTION_API_KEY=
NOTION_BLOG_DATABASE_ID=
