# 카카오맵 JavaScript 앱 키
# https://developers.kakao.com 에서 발급
# 1. 카카오 개발자 사이트 접속 → 내 애플리케이션 → 앱 추가
# 2. 앱 키 → JavaScript 키 복사
# 3. 플랫폼 → Web 사이트 도메인 등록 (예: http://localhost:3000)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_map_app_key_here

# Supabase (DB + Auth)
# https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 관리자 대시보드 접근 허용 이메일 (쉼표 구분)
ADMIN_EMAILS=kcgcom@gmail.com

# 관리자 대시보드 — 트래픽 탭 (GA4 Data API)
# Google Analytics → 관리 → 속성 설정 → 속성 ID (숫자만)
GA4_PROPERTY_ID=525397980

# 관리자 대시보드 — 검색/SEO 탭 (Search Console API)
# sc-domain:도메인 또는 https://도메인 형식
SEARCH_CONSOLE_SITE_URL=sc-domain:born2smile.co.kr

# 관리자 대시보드 — 검색/SEO 탭 네이버 트렌드 (DataLab API)
# https://developers.naver.com/apps → 애플리케이션 등록 → 데이터랩(검색어트렌드) 선택
NAVER_DATALAB_CLIENT_ID=your_naver_client_id_here
NAVER_DATALAB_CLIENT_SECRET=your_naver_client_secret_here

# 개발 대시보드 — 성능 탭 (PageSpeed Insights API)
# https://console.cloud.google.com/apis/credentials → API 키 생성
# PageSpeed Insights API 활성화 필요: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Google 서비스 계정 JSON 키 (GA4/Search Console API, 로컬 개발용)
# 프로덕션은 Cloud Run ADC 사용
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...",...}
# 선택: GA4 호출에 사용할 활성 Google Cloud 프로젝트/Quota Project
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_QUOTA_PROJECT=
