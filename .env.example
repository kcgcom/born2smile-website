# 카카오맵 JavaScript 앱 키
# https://developers.kakao.com 에서 발급
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_map_app_key_here

# Supabase (DB + Auth)
# https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 관리자 대시보드 접근 허용 이메일 (쉼표 구분)
ADMIN_EMAILS=kcgcom@gmail.com

# GA4 / Search Console
GA4_PROPERTY_ID=525397980
SEARCH_CONSOLE_SITE_URL=sc-domain:born2smile.co.kr
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# 네이버 DataLab API
NAVER_DATALAB_CLIENT_ID=your_naver_client_id_here
NAVER_DATALAB_CLIENT_SECRET=your_naver_client_secret_here

# 네이버 검색광고 API (절대 검색량)
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

# PageSpeed Insights API
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Vercel Cron + IndexNow
CRON_SECRET=your_random_cron_secret_here
INDEXNOW_KEY=

# Sentry (에러 모니터링)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_ENVIRONMENT=production
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog (전환/CTA 리포트)
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://x.born2smile.co.kr
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=
POSTHOG_BASE_URL=https://us.posthog.com

# 관리자 대시보드 — AI 블로그 작성 도우미
LLM_BASE_URL=https://llm.born2smile.co.kr
LLM_MODEL=fast
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=
LLM_UPSTREAM_TIMEOUT_MS=55000
