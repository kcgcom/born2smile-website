{
  "name": "born2smile-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate-blog-meta": "tsx scripts/generate-blog-meta.ts",
    "generate-dev-manifest": "tsx scripts/generate-dev-manifest.ts",
    "dev": "tsx scripts/generate-blog-meta.ts && tsx scripts/generate-dev-manifest.ts && next dev",
    "build": "tsx scripts/generate-blog-meta.ts && tsx scripts/generate-dev-manifest.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "firebase deploy --only apphosting",
    "review-status": "tsx scripts/review-status.ts",
    "submit-indexnow": "node scripts/submit-indexnow.mjs",
    "submit-indexnow:all": "node scripts/submit-indexnow.mjs --all"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pretendard": "^1.3.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "browserslist": [
    "chrome >= 87",
    "firefox >= 78",
    "safari >= 14",
    "edge >= 88"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "ajv@<6.14.0": "6.14.0",
      "fast-xml-parser@<5.3.8": "5.3.8"
    }
  }
}
