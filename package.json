{
  "name": "born2smile-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate-blog-meta": "tsx scripts/generate-blog-meta.ts",
    "generate-blog-snapshot": "tsx scripts/generate-blog-snapshot.ts",
    "generate-research-snapshot": "tsx scripts/generate-research-snapshot.ts",
    "generate-keyword-taxonomy-snapshot": "tsx scripts/generate-keyword-taxonomy-snapshot.ts",
    "verify-keyword-taxonomy": "tsx scripts/verify-keyword-taxonomy-state.ts",
    "verify-keyword-taxonomy-contract": "tsx scripts/verify-keyword-taxonomy-contract.ts",
    "verify-taxonomy-refresh-flow": "tsx scripts/verify-taxonomy-refresh-flow.ts",
    "verify-opportunity-scoring": "tsx scripts/verify-opportunity-scoring.ts",
    "verify-content-coverage-contract": "tsx scripts/verify-content-coverage-contract.ts",
    "report-content-coverage-baseline": "tsx scripts/report-content-coverage-baseline.ts",
    "report-content-coverage-semantic": "tsx scripts/report-content-coverage-semantic.ts",
    "report-content-coverage-concept-shadow": "tsx scripts/report-content-coverage-concept-shadow.ts",
    "generate-content-coverage-retrieval-review": "tsx scripts/generate-content-coverage-retrieval-review.ts",
    "evaluate-content-coverage-retrieval": "tsx scripts/evaluate-content-coverage-retrieval.ts",
    "report-opportunity-scoring": "tsx scripts/report-opportunity-scoring.ts",
    "evaluate-keyword-embeddings": "tsx scripts/evaluate-keyword-embeddings.ts",
    "generate-dev-manifest": "tsx scripts/generate-dev-manifest.ts",
    "dev": "tsx scripts/generate-blog-snapshot.ts && tsx scripts/generate-blog-meta.ts && tsx scripts/generate-dev-manifest.ts && tsx scripts/generate-research-snapshot.ts && tsx scripts/generate-keyword-taxonomy-snapshot.ts && BLOG_PUBLIC_DATA_SOURCE=snapshot next dev",
    "build": "BLOG_SNAPSHOT_REQUIRED=true tsx scripts/generate-blog-snapshot.ts && tsx scripts/generate-blog-meta.ts && tsx scripts/generate-dev-manifest.ts && tsx scripts/generate-research-snapshot.ts && tsx scripts/generate-keyword-taxonomy-snapshot.ts && BLOG_PUBLIC_DATA_SOURCE=snapshot NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "vercel --prod",
    "review-status": "tsx scripts/review-status.ts",
    "revalidate-blog": "node scripts/revalidate-blog-post.mjs",
    "submit-indexnow": "node scripts/submit-indexnow.mjs",
    "submit-indexnow:all": "node scripts/submit-indexnow.mjs --all",
    "db:sql": "supabase db query --linked",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@vercel/analytics": "^2.0.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "posthog-js": "^1.364.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "browserslist": [
    "chrome >= 87",
    "firefox >= 78",
    "safari >= 14",
    "edge >= 88"
  ],
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "ajv@<6.14.0": "6.14.0",
      "fast-xml-parser@<5.3.8": "5.3.8"
    }
  }
}
